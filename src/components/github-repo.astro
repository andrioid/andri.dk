---
import { Icon as BaseIcon } from "astro-icon/components";
import { getStars } from "~/lib/github-cache";

interface Props {
	repo: string; // "owner/repo" format, e.g. "andrioid/andri.dk"
}

const { repo } = Astro.props;
const stars = await getStars(repo);
const href = `https://github.com/${repo}`;
---

<a
	href={href}
	target="_blank"
	rel="noopener noreferrer"
	class="inline-flex items-center gap-1.5 rounded-md border border-gray-300 bg-gray-50 px-2.5 py-1 text-sm font-medium text-gray-700 no-underline hover:bg-gray-100 hover:border-gray-400 transition-colors"
>
	<BaseIcon name="tabler:brand-github" class="inline w-4 h-4" />
	{
		stars !== null ? (
			<>
				<BaseIcon
					name="tabler:star-filled"
					class="inline w-3.5 h-3.5 text-amber-500"
				/>
				<span>{stars.toLocaleString()}</span>
			</>
		) : (
			<span>Star on GitHub</span>
		)
	}
</a>
