---
import Icon from "./Icon.astro";
import Tag from "./tag.astro";

export interface Props {
	title: string;
	description?: string;
	date?: Date;
	link: string;
	tags?: string[];
	draft?: boolean;
}

const { title, date, tags, draft = false } = Astro.props as Props;
let link = Astro.props.link;

if (link[link.length - 1] !== "/") {
	link += "/"; // Enforce trailing slash
}
---

<a class="block" href={link}>
	<div
		class="flex flex-col p-6 h-full shadow-lg bg-white hover:shadow-2xl text-primary-700 md:rounded-md"
	>
		<div class="flex flex-col justify-start">
			<span class="text-sm inline-flex items-center gap-1 mb-1">
				<Icon name="calendar" class="h-5 w-5" />
				{
					date && (
						<>
							<span class="ml-1">
								{date.toLocaleDateString(undefined, {
									year: "numeric",
									month: "short",
									day: "numeric",
								})}
							</span>
						</>
					)
				}
			</span>

			<div class="mt-1 font-medium text-lg text-primary-500">
				{title}
			</div>
		</div>
		{
			tags && tags.length > 0 ? (
				<div class="mt-4 gap-2 flex">
					{tags.slice(0, 3).map((t) => (
						<Tag tag={t} />
					))}
					{draft ? <Tag tag="draft" /> : null}
				</div>
			) : null
		}
	</div>
</a>
